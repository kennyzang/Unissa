{
  "name": "unissa-poc",
  "version": "1.0.0",
  "private": true,
  "description": "UNISSA Smart University Platform – Full-Stack POC",
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "build": "pnpm --filter backend build && pnpm --filter frontend build",
    "seed": "pnpm --filter backend seed",
    "db:reset": "pnpm --filter backend db:reset"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "dependencies": {
    "@lui/core": "^6.0.10",
    "@lui/icons": "^6.0.10",
    "@lui/pro": "^6.0.10",
    "@mui/core": "^6.0.10",
    "@mui/pro": "^6.0.10"
  }
}
