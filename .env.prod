# ============================================================
# UNISSA 生产环境配置
# ============================================================

# JWT（必须修改为随机强密钥，至少32位）
JWT_SECRET="unissa-poc-secret-key-123456789012345678901234"
JWT_EXPIRES_IN="8h"

# CORS（替换为你的实际域名）
CORS_ORIGIN="*"

# AI 配置（可在系统管理后台设置，也可在此填写）
# 支持: openai | anthropic | custom
AI_PROVIDER=""
AI_API_KEY=""
AI_MODEL=""
AI_BASE_URL=""

# 文件存储（使用本地存储则留空）
MINIO_ENDPOINT=""
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""

# Web Push 通知（可选，留空则禁用推送）
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# 邮件发送（可选，留空则禁用邮件）
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
